{
  "defaultPlacement": "overlay",
  "settings": {
    "previewScrollUp": "shift+up",
    "previewScrollDown": "shift+down",
    "previewScrollLines": 5
  },
  "commands": {
    "file": {
      "list": "fd --type f --max-depth 4",
      "action": "@{{selected}}",
      "preview": "batcat --style=numbers --color=always {{selected}} 2>/dev/null || cat {{selected}} 2>/dev/null",
      "shortcut": "ctrl+shift+f"
    },
    "explain": {
      "list": "fd --type f --max-depth 4",
      "action": "Read and explain {{selected}}",
      "preview": "batcat --style=numbers --color=always {{selected}} 2>/dev/null || cat {{selected}} 2>/dev/null"
    },
    "skill": {
      "list": "fd -L 'SKILL.md' ~/.pi/agent/skills ~/.pi/agent/git ~/.agents/skills 2>/dev/null | sed -E 's|.*/skills/([^/]+)/SKILL\\.md|\\1|' | grep -v '/' | sort -u",
      "action": { "type": "editor", "template": "/skill:{{selected}}" }
    },
    "branch": {
      "list": "git branch --format='%(refname:short)' 2>/dev/null || true",
      "action": { "type": "bash", "template": "git checkout {{selected}}" },
      "preview": "git log --oneline -10 {{selected}} 2>/dev/null"
    },
    "git-diff": {
      "list": "git diff --name-only",
      "multiSelect": true,
      "action": {
        "type": "bash",
        "template": "printf '%s\\n' '{{selected}}' | xargs -I{} git diff -- \"{}\"",
        "output": "editor"
      }
    },
    "todo": {
      "list": "rg -l 'TODO|FIXME' || true",
      "action": {
        "type": "editor",
        "template": "Find and fix all TODOs in {{selected}}"
      },
      "preview": "rg -n 'TODO|FIXME' {{selected}} 2>/dev/null"
    }
  }
}
